# Backend API base URL (no trailing slash)
# Development: http://localhost:8000/api/v1
# Production:  https://api.bharatmock.com/api/v1
NEXT_PUBLIC_API_URL=https://api.bharatmock.com/api/v1

# GraphQL endpoint (optional — derived from NEXT_PUBLIC_API_URL if not set)
# NEXT_PUBLIC_GRAPHQL_URL=https://api.bharatmock.com/api/graphql

# Public site URL (no trailing slash) — used for canonical URLs and OG tags
NEXT_PUBLIC_SITE_URL=https://bharatmock.com

# Google OAuth Client ID
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# Razorpay publishable key (for payment UI)
NEXT_PUBLIC_RAZORPAY_KEY_ID=your-razorpay-key-id

# Google Cloud Translation API key — SERVER ONLY (do NOT use the NEXT_PUBLIC_ prefix:
# that inlines the key into the client bundle at build time and leaks it publicly).
GOOGLE_CLOUD_TRANSLATION_API_KEY=your-google-cloud-translation-api-key

# Shared secret attached to server-to-server API calls (session check + SSR page
# fetches) so the backend exempts them from per-IP rate limiting. Without it, every
# visitor's server-side request collapses into one backend rate-limit bucket and the
# site 429s/404s under load. MUST match the backend's INTERNAL_PROXY_SECRET exactly.
# Server-only — never prefix NEXT_PUBLIC. Generate: openssl rand -hex 32
INTERNAL_PROXY_SECRET=your-shared-internal-proxy-secret
